       :height "650"}]])},
  #uuid "b42dfbba-7dd1-47c5-9e9b-6df2cb98e6f0"
  {:unit/title "Unbalanced Cluster Distribution",
   :unit/id #uuid "b42dfbba-7dd1-47c5-9e9b-6df2cb98e6f0",
   :unit/type :unit/book,
   :unit/pos [3634.0926574985383 -2737.0608691313064],
   :unit/child-unit-ids
   [#uuid "2883b8f9-7633-4451-82d9-32908187f3e9"
    #uuid "5a217bd9-2e66-48c9-a04b-2bdea1c59dde"],
   :unit/props
   {:props/title-size :props/h2, :props/color :color/blue}},
  #uuid "41c56c4c-4345-4c99-acc4-e9041653766c"
  {:unit/parent-id #uuid "936ef5d3-7c67-469c-b4c8-606c3ec3c687",
   :unit/id #uuid "41c56c4c-4345-4c99-acc4-e9041653766c",
   :unit/type :unit/page,
   :unit/content
   ([:ul
     [:li "indexes data and exposes http-api / graphQL"]
     [:li "often provides also analytical insights "]
     [:li
      [:strong "Centralized"]
      [:ul
       [:li "making " [:strong "projections"] " into powerful DB"]
       [:li "hard to incentivize people to run it"]]]
     [:li
      [:strong "Decentralized"]
      "  : "
      [:a {:href "https://thegraph.com/"} "The Graph"]
      [:ul
       [:li "introduced incentivization model "]
       [:li "inversion of control, let index those who need it"]
       [:li
        [:strong "subgraphs"]
        " of only parts of the chain that are relevant to them"]]]
     [:li
      "Indexing blockchain challenges\n"
      [:ul
       [:li "handling forks, rollbacks / reverting data"]
       [:li "various transaction formats and assets"]
       [:li "partition size in Cassandra, JOINs in RDBM"]]]])},
  #uuid "2a8fe17b-0c37-465e-b3d3-61903e46ee2b"
