 {#uuid "366ca6aa-571e-4a81-bd37-2c210f7e8e8a"
  {:unit/title "Modern Centralized Core Architecture in Scala",
   :unit/id #uuid "366ca6aa-571e-4a81-bd37-2c210f7e8e8a",
   :unit/type :unit/book,
   :unit/pos [2313.478244399797 -1624.6711436995358],
   :unit/child-unit-ids [#uuid "84681a2f-9af5-49bc-868f-d942a51db5d2"],
   :unit/props
   {:props/title-size :props/h2, :props/color :color/blue}},
  #uuid "150f754d-c01b-420c-a3de-53bccd3a401c"
  {:unit/parent-id #uuid "d8f90dfd-e2a6-4489-8f1f-a8936a2d942d",
   :unit/id #uuid "150f754d-c01b-420c-a3de-53bccd3a401c",
   :unit/type :unit/page,
   :unit/content
   ([:p
     "How sustainability is done? Through further decentralization."]
    [:p
     {:style {:text-align "center"}}
     [:img
      {:width "962",
       :src "/img/BudYBNN-RJ95w2E9WeYNqP",
       :height "624"}]])},
  #uuid "0f0aaf63-19c9-408c-bcf2-4fc91235a347"
  {:unit/title "Centralized problems",
   :unit/id #uuid "0f0aaf63-19c9-408c-bcf2-4fc91235a347",
   :unit/type :unit/book,
   :unit/pos [4878.106686596614 -1644.8352250294972],
   :unit/child-unit-ids [#uuid "d51d6e45-ab53-488a-b663-442410035440"],
   :unit/props
   {:props/title-size :props/h2, :props/color :color/blue}},
  #uuid "c76ec46c-dd83-45c5-a733-1352319b6b18"
  {:unit/parent-id #uuid "8320d0cc-6244-45da-bd76-c2d852d18f30",
   :unit/id #uuid "c76ec46c-dd83-45c5-a733-1352319b6b18",
   :unit/type :unit/page,
   :unit/content
   ([:ul
     [:li
      "Many specifications showed up over time\n"
      [:ul
       [:li [:strong "ISO20022"] " - unified messaging format"]
       [:li [:strong "FIX"] " - real-time messaging format"]
       [:li [:strong "FpML"] " - describes financtial products "]
       [:li
        [:strong "CBPR+"]
        " - f"
        "ramework for enhancing cross-border payments developed by CPMI and IOSCO"]
       [:li
        [:strong "ISDA "]
        "- International Swaps and Derivatives Association"]
       [:li
        [:strong "PCI DSS"]
        " - "
        "security standards designed to ensure that all companies that accept, process, store, or transmit credit card information maintain a secure environment"]]]]
    [:p {:style {:text-align "center"}}])},
  #uuid "84681a2f-9af5-49bc-868f-d942a51db5d2"
  {:unit/parent-id #uuid "366ca6aa-571e-4a81-bd37-2c210f7e8e8a",
   :unit/id #uuid "84681a2f-9af5-49bc-868f-d942a51db5d2",
   :unit/type :unit/page,
   :unit/content
   ([:ul
     [:li
      [:strong "CQRS "]
      "- Scala/Akka has wonderful framework built-in\n"
      [:ul
       [:li "causality principles (action/reaction), FSM "]
       [:li "in-memory State accessible in real-time"]]]
     [:li
      [:strong "Actors"]
      " (entities) distributed in shards of nodes in a "
      [:strong "cluster"]]
     [:li
      "Each actor is being sourced relevant transactions\n"
      [:ul
       [:li
        "building its "
        [:strong "account"]
        " balance in-memory (fast-access)"]]]
     [:li
      "Each Transaction is used for building general projections\n"
      [:ul [:li [:strong "Projections"] " are part of the design"]]]]
    [:p
     [:img
      {:width "967",
       :src "/img/BRK2A1Bz1CE5Gw-FTEFF5r",
       :style {:text-align "center"},
       :height "145"}]])},
  #uuid "936ef5d3-7c67-469c-b4c8-606c3ec3c687"
  {:unit/title "Blockchain Explorer decentralization",
   :unit/id #uuid "936ef5d3-7c67-469c-b4c8-606c3ec3c687",
   :unit/type :unit/book,
   :unit/pos [4866.893045732929 659.7967618652763],
   :unit/child-unit-ids [#uuid "41c56c4c-4345-4c99-acc4-e9041653766c"],
   :unit/props
   {:props/title-size :props/h2, :props/color :color/blue}},
  #uuid "953e0708-7bb4-46e1-a32b-9996743bcfdb"
  {:unit/title "Blockchain Standards",
   :unit/id #uuid "953e0708-7bb4-46e1-a32b-9996743bcfdb",
   :unit/type :unit/book,
   :unit/pos [2304.1371092094723 645.4880270749254],
