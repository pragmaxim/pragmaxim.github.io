       :src "/img/B4fLUaIw1KGrw2UaMCtQoz",
       :style {:text-align "center"},
       :height "830"}]])},
  #uuid "47ac099b-0b77-46df-9186-2506ddbedef9"
  {:unit/parent-id #uuid "0f83d398-c2f6-4d1a-9015-bbce1a887b44",
   :unit/id #uuid "47ac099b-0b77-46df-9186-2506ddbedef9",
