  #uuid "6b21ceaa-2795-4cb0-b0e5-9ce78e4bcbda"
  {:unit/title "Unbalanced Data Distribution",
   :unit/id #uuid "6b21ceaa-2795-4cb0-b0e5-9ce78e4bcbda",
   :unit/type :unit/book,
   :unit/pos [4876.317870748788 -2655.9211138807036],
   :unit/child-unit-ids [#uuid "dcd4f744-487e-4da6-8217-d6eb4919afa3"],
   :unit/props
   {:props/title-size :props/h2, :props/color :color/blue}},
  #uuid "db7ab42d-431e-4d39-8002-d2b1295b1922"
  {:unit/parent-id #uuid "d1397c24-d2ec-4a21-b8fd-ba6164d3ebfb",
   :unit/id #uuid "db7ab42d-431e-4d39-8002-d2b1295b1922",
   :unit/type :unit/page,
   :unit/content
   ([:p
     {:style {:text-align "center"}}
     [:img
      {:width "488",
       :src "/img/A_IskaKzpFf4LjUG-mxZvE",
       :style {:text-align "center"},
       :height "835"}]])},
  #uuid "548f91f6-57ca-4b6a-a9e3-6f538650b228"
  {:unit/parent-id #uuid "d1397c24-d2ec-4a21-b8fd-ba6164d3ebfb",
   :unit/id #uuid "548f91f6-57ca-4b6a-a9e3-6f538650b228",
   :unit/type :unit/page,
   :unit/content
   ([:p "Specialization on"]
    [:ul [:li "distributed data processing"] [:li "blockchains"]]
    [:p "using mainly"]
    [:ul
     [:li
      [:a {:href "https://www.scala-lang.org/"} "Scala"]
      " ecosystem"]
     [:li [:a {:href "https://zio.dev/"} "ZIO"]]
     [:li
      [:a {:href "https://akka.io/"} "Akka"]
      " based implementations of CQRS"]]
    [:p
     "Ideally sustainable, green, meaningful or complexity reducing software that makes the world a better place."])},
  #uuid "0f83d398-c2f6-4d1a-9015-bbce1a887b44"
  {:unit/title "CQRS (Command-Query-Responsibility-Segregation)",
   :unit/id #uuid "0f83d398-c2f6-4d1a-9015-bbce1a887b44",
   :unit/type :unit/book,
   :unit/pos [3635.0603378415467 -1665.2842368994452],
   :unit/child-unit-ids
   [#uuid "47ac099b-0b77-46df-9186-2506ddbedef9"
    #uuid "7df97e03-17e2-40e8-b128-a19130a49b22"],
   :unit/props
   {:props/title-size :props/h2, :props/color :color/blue}},
  #uuid "859eae0e-de42-497d-8ac4-4b484e868cd1"
  {:unit/parent-id #uuid "2a8fe17b-0c37-465e-b3d3-61903e46ee2b",
   :unit/id #uuid "859eae0e-de42-497d-8ac4-4b484e868cd1",
   :unit/type :unit/page,
   :unit/content
   ([:p
     [:img
      {:width "847",
       :src "/img/D0tTlK0CRBSIyVzQAoP9kZ",
       :height "635"}]])},
  #uuid "d8f90dfd-e2a6-4489-8f1f-a8936a2d942d"
  {:unit/title "Relay & Para Chains",
   :unit/id #uuid "d8f90dfd-e2a6-4489-8f1f-a8936a2d942d",
   :unit/type :unit/book,
   :unit/pos [3603.6881761497507 -427.6253097894896],
   :unit/child-unit-ids [#uuid "150f754d-c01b-420c-a3de-53bccd3a401c"],
   :unit/props
   {:props/title-size :props/h2, :props/color :color/blue}},
  #uuid "b1d4982f-5f12-4574-879d-45d9953d3aa8"
  {:unit/parent-id #uuid "5a5b2993-2adb-4af5-a7b8-551a2d761599",
   :unit/id #uuid "b1d4982f-5f12-4574-879d-45d9953d3aa8",
   :unit/type :unit/page,
   :unit/content
   ([:p
     [:strong "WW II"]
     " (Bretton Woods system): 3 decades of regulation, fixed exchange and interest rates worldwide provided some financial stability"]
    [:p
     [:strong "1970s - 2008"]
     " : deregulation => massive techno-feudalism and inflation as we know it today"]
    [:ul
     [:li
      "1970s : Nixon shock, floating exchange rates, end of gold standard"]
     [:li "1980s : rise of derivatives, junk bonds, etc."]
     [:li "1990s : rise of securitization, subprime mortgages, etc."]]
    [:p [:strong "2008+ "] ": printing money"]
    [:ul
     [:li
      "amount of transactions increasing exponentially since Web2.0"]])},
  #uuid "7068432d-5216-4809-a2fc-23dc342a9bd2"
  {:unit/title "Centralized vs Decentralized",
   :unit/id #uuid "7068432d-5216-4809-a2fc-23dc342a9bd2",
   :unit/type :unit/book,
   :unit/pos [-101.12975855042403 -2630.107770511346],
   :unit/child-unit-ids [#uuid "404b8715-6370-4477-970c-633fbbb393d7"],
   :unit/props
   {:props/title-size :props/h2, :props/color :color/blue}},
  #uuid "404b8715-6370-4477-970c-633fbbb393d7"
  {:unit/parent-id #uuid "7068432d-5216-4809-a2fc-23dc342a9bd2",
   :unit/id #uuid "404b8715-6370-4477-970c-633fbbb393d7",
   :unit/type :unit/page,
   :unit/content
   ([:p
     [:img
      {:width "946",
       :src "/img/DEZfr1wVJOaqmG6MoNSFzT",
       :style {:text-align "center"},
       :height "424"}]])},
  #uuid "dcd4f744-487e-4da6-8217-d6eb4919afa3"
  {:unit/parent-id #uuid "6b21ceaa-2795-4cb0-b0e5-9ce78e4bcbda",
   :unit/id #uuid "dcd4f744-487e-4da6-8217-d6eb4919afa3",
   :unit/type :unit/page,
   :unit/content
   ([:ul
     [:li "PostgresSQL : custom DB optimizations / pagination"]
     [:li "Cassandra : hash/time/range partitioning + denormalization"]
     [:li "using Cloud Storages for $ : BigTable / BigQuery"]]
    [:p
     {:style {:text-align "center"}}
     [:img
      {:width "843",
       :src "/img/CH3Wy-gTxOhLs2tUn3nDRm",
       :height "590"}]])},
  #uuid "d51d6e45-ab53-488a-b663-442410035440"
  {:unit/parent-id #uuid "0f0aaf63-19c9-408c-bcf2-4fc91235a347",
   :unit/id #uuid "d51d6e45-ab53-488a-b663-442410035440",
   :unit/type :unit/page,
   :unit/content
   ([:ul
     [:li
      [:strong "Settlement layer"]
      [:ul
       [:li "complex nightmare causing magic "]
       [:li
        "finality of Visa Payment Tx (reaching consensus) might take up to 3 days, the payment Fee is ~ 2%"]
       [:li
        "new parties or banks cannot easily join the centralized system or cluster"]]]
     [:li
      "inconsistency\n"
      [:ul
       [:li
        "we rely on database ACID capabilities, write thorough tests with fingers crossed (no cryptographical proofs)"]]]
     [:li
      "A lot of State to keep = "
      [:strong "bad for Functional Programming"]]
     [:li [:strong "privacy"]]])},
  #uuid "53fa8f50-23de-420a-a122-973e4b5b1528"
  {:unit/parent-id #uuid "d1397c24-d2ec-4a21-b8fd-ba6164d3ebfb",
   :unit/id #uuid "53fa8f50-23de-420a-a122-973e4b5b1528",
   :unit/type :unit/page,
   :unit/content
   ([:p
     "Scala, Akka & ZIO help me to be useful and solve problems which is an opportunity to become even more useful and solve problems better by :"]
    [:ul
     [:li
      "deeper understanding of some domain like Fintech and transaction processing software"]
     [:li
      "exploring new domains as people evolve this way and learn to look at the world differently "]])},
  #uuid "e7603c8f-7388-4d5a-bb67-8bc30e5d86db"
  {:unit/parent-id #uuid "dc5427bd-a651-4b85-adbc-d20fdad28552",
   :unit/id #uuid "e7603c8f-7388-4d5a-bb67-8bc30e5d86db",
   :unit/type :unit/page,
   :unit/content
   ([:ul
     [:li "Robust multi-client wallet backed by DB"]
     [:li "classic cryptography : PGP, BouncyCastle"]
     [:li
      [:a
       {:href "https://github.com/pragmaxim/scalapass-cli"}
       "https://github.com/pragmaxim/zio-pass"]]])},
  #uuid "053f25f3-6cc0-4226-aaa1-6262448a949a"
  {:unit/title "Decentralized Apps",
   :unit/id #uuid "053f25f3-6cc0-4226-aaa1-6262448a949a",
   :unit/type :unit/book,
   :unit/pos [1062.289934591691 674.0540592662434],
   :unit/child-unit-ids [#uuid "0d0f14c6-ad37-4330-ae50-438628f1f7c4"],
   :unit/props
   {:props/title-size :props/h2, :props/color :color/blue}},
  #uuid "55f6281e-49bf-41a2-89fa-c5b0345bd982"
  {:unit/parent-id #uuid "b781c423-c217-4aba-9e6b-6e184b2dceb8",
   :unit/id #uuid "55f6281e-49bf-41a2-89fa-c5b0345bd982",
   :unit/type :unit/page,
   :unit/content
   ([:ul
     [:li
      "Merkelized Trie Database : "
      [:a {:href "https://github.com/ava-labs/firewood/"} "Firebase"]]
     [:li
      "Patricia Merkle Trie on RocksDB : "
      [:a {:href "https://github.com/paritytech/trie"} "Trie-db"]]
     [:li
      "Authenticated Dynamic Dictionaries : "
      [:a
       {:href "https://github.com/ergoplatform/ergo/tree/master/avldb"}
       "AVL+ tree"]]]
    [:p
     {:style {:text-align "center"}}
     [:img
      {:width "910",
       :src "/img/DCIvFcYHRF1I8BjKZ9oD1M",
       :height "643"}]])},
  #uuid "5a217bd9-2e66-48c9-a04b-2bdea1c59dde"
  {:unit/parent-id #uuid "b42dfbba-7dd1-47c5-9e9b-6df2cb98e6f0",
   :unit/id #uuid "5a217bd9-2e66-48c9-a04b-2bdea1c59dde",
   :unit/type :unit/page,
   :unit/content
   ([:p [:strong "Problem"]]
    [:p]
    [:ul
     [:li
      "Nodes can have different concentration of Whales and Sharks\n"
      [:ul [:li "pay-for-service transactions"] [:li "day trading "]]]]
    [:p "⇒ performance issues, bottlenecks, replay time varies, etc."]
    [:p [:strong "Solution"]]
    [:ul [:li "rank-based cluster rebalancing"]])},
  #uuid "2883b8f9-7633-4451-82d9-32908187f3e9"
  {:unit/parent-id #uuid "b42dfbba-7dd1-47c5-9e9b-6df2cb98e6f0",
   :unit/id #uuid "2883b8f9-7633-4451-82d9-32908187f3e9",
   :unit/type :unit/page,
   :unit/content
   ([:p
     {:style {:text-align "center"}}
     [:img
      {:width "915",
       :src "/img/Bhs-MjjgZOEamQCU3neoZj",
       :height "661"}]])},
  #uuid "53035eb0-81df-4711-9db6-e65cbfa215ac"
  {:unit/title "Advantages of decentralization",
   :unit/id #uuid "53035eb0-81df-4711-9db6-e65cbfa215ac",
   :unit/type :unit/book,
   :unit/pos [4863.197795372148 -447.60039870752917],
   :unit/child-unit-ids [#uuid "3752dae9-bfac-4f4b-b355-8e4dcb157878"],
   :unit/props
   {:props/title-size :props/h2, :props/color :color/blue}},
  #uuid "ba50c269-ced7-4447-a09b-3fba20bb7846"
  {:unit/title "Paradigm shift through analogy",
   :unit/id #uuid "ba50c269-ced7-4447-a09b-3fba20bb7846",
   :unit/type :unit/book,
   :unit/pos [-118.26721359599102 -1937.6793420466136],
   :unit/child-unit-ids [#uuid "e7ecc995-3d30-480e-b497-a7d1803b1478"],
   :unit/props
   {:props/title-size :props/h2, :props/color :color/blue}},
  #uuid "e7ecc995-3d30-480e-b497-a7d1803b1478"
  {:unit/parent-id #uuid "ba50c269-ced7-4447-a09b-3fba20bb7846",
   :unit/id #uuid "e7ecc995-3d30-480e-b497-a7d1803b1478",
   :unit/type :unit/page,
   :unit/content
   ([:p "What software reminds me of"]
    [:ul
     [:li
      [:strong "Centralized"]
      "  - totalitarian state and centrally controlled economy"]
     [:li
      [:strong "Decentralized"]
      " - democratic state and free economy (slightly utopian)"]
     [:li
      [:strong "Hybrid"]
      "  - realistic balance and sustainability"]])},
  #uuid "5c94c570-6b48-423c-a068-6d9f6a6a5580"
  {:unit/parent-id #uuid "deb3fcb2-4ff0-45be-8e38-ca8c85b50318",
   :unit/id #uuid "5c94c570-6b48-423c-a068-6d9f6a6a5580",
   :unit/type :unit/page,
   :unit/content
   ([:p [:strong "Satoshi Nakamoto"]]
    [:ul
     [:li "academia + many years of working in Fintech"]
     [:li "democratized and open-sourced banking"]
     [:li "inspired by decentralized file sharing"]]
    [:p [:strong "2. generation of blockchains"]]
    [:ul
     [:li "self-governance : DAO"]
     [:li "general-purpose, rich smart-contracts"]
     [:li "sustainability issues and bottlenecks"]]
    [:p [:strong "3. generation of blockchains"]]
    [:ul
     [:li
      "high throughput, low finality : Solana, Avalanche\n"
      [:ul [:li "merkle-tree DB replacement of RocksDB"]]]
     [:li
      "Relay-chain & Para-chain combination \n"
      [:ul [:li "sustainability "]]]])},
  #uuid "f7579d56-cae2-4466-80d2-1c2e521a1a0a"
  {:unit/parent-id #uuid "22d33959-323f-4fbe-910e-3541324a5452",
   :unit/id #uuid "f7579d56-cae2-4466-80d2-1c2e521a1a0a",
   :unit/type :unit/page,
   :unit/content
   ([:ul
     [:li
      [:strong "Settlement"]
      " between all involved parties\n"
      [:ul
       [:li
        "all parties need to reach "
        [:strong "concensus"]
        " about "
        [:strong "State"]]
       [:li [:strong "finality"] " = time required to reach consensus"]
       [:li [:strong "throughput"] " = how many txs/s"]]]
     [:li
      [:strong "Event Sourcing"]
      " - causality based, replayable sequence of "
      [:strong "action & reaction"]
      " => quickly accessable State "]
     [:li
      [:strong "Transaction Log"]
      " => "
      [:strong "Account Balances"]
      [:ul
       [:li
        [:strong "Transaction"]
        " is mostly a container of asset transfers between accounts\n"
        [:ul
         [:li
          [:strong "Asset"]
          " = Fiat, anything of value, ownership"]
         [:li
          [:strong "Account"]
          " represents a balance, a container of assets"]]]]]
     [:li
      [:strong "Projections"]
      " of Transation Log to get better insights"]]
    [:p])},
  #uuid "0d0f14c6-ad37-4330-ae50-438628f1f7c4"
  {:unit/parent-id #uuid "053f25f3-6cc0-4226-aaa1-6262448a949a",
   :unit/id #uuid "0d0f14c6-ad37-4330-ae50-438628f1f7c4",
   :unit/type :unit/page,
   :unit/content
   ([:p
     {:style {:text-align "center"}}
     [:img
      {:width "976",
       :src "/img/A66XfemdNAfoRSWm6SpFPB",
       :height "735"}]])},
  #uuid "22d33959-323f-4fbe-910e-3541324a5452"
  {:unit/title "Shared traits of Centralized & Decentralized worlds",
   :unit/id #uuid "22d33959-323f-4fbe-910e-3541324a5452",
   :unit/type :unit/book,
   :unit/pos [-126.83640367602213 -1057.5536258162897],
   :unit/child-unit-ids [#uuid "f7579d56-cae2-4466-80d2-1c2e521a1a0a"],
   :unit/props
   {:props/title-size :props/h2, :props/color :color/blue}},
  #uuid "3752dae9-bfac-4f4b-b355-8e4dcb157878"
  {:unit/parent-id #uuid "53035eb0-81df-4711-9db6-e65cbfa215ac",
   :unit/id #uuid "3752dae9-bfac-4f4b-b355-8e4dcb157878",
   :unit/type :unit/page,
   :unit/content
   ([:ul
     [:li
      "Clean standards of "
      [:strong "Settlement/Consensus layer"]
      [:ul
       [:li
        "in "
        [:strong "peer-2-peer"]
        " network\n"
        [:ul
         [:li " any party can join"]
         [:li
          [:strong "good for Functional Programming"]
          " as only State to keep is Mempool of Txs and Peers "]]]
       [:li
        "Fast finality - time required to reach consensus"
        [:br]
        [:ul
         [:li
          [:a {:href "https://solana.com/"} "Solana"]
          "/"
          [:a {:href "https://www.avax.network/"} "Avalanche"]]]]
       [:li
        "consistency - provably correct datastructures\n"
        [:ul
         [:li
          [:a
           {:href "https://github.com/ava-labs/firewood/"}
           "Merkle tree database"]
          " "]]]]]
     [:li
      "privacy\n"
      [:ul
       [:li "users own the data"]
       [:li
        [:a
         {:href "https://en.wikipedia.org/wiki/Zero-knowledge_proof"}
         "ZK proofs"]
        ", "
        [:a
         {:href "https://en.wikipedia.org/wiki/Ring_signature"}
         "Ring signatures"]]]]])},
  #uuid "7df97e03-17e2-40e8-b128-a19130a49b22"
  {:unit/parent-id #uuid "0f83d398-c2f6-4d1a-9015-bbce1a887b44",
   :unit/id #uuid "7df97e03-17e2-40e8-b128-a19130a49b22",
   :unit/type :unit/page,
   :unit/content
   ([:ul
     [:li
      "ideal use-case for distributed Actor System\n"
      [:ul
       [:li "centralized on a single cluster"]
       [:li "akka persistence + query"]
       [:li
        "each actor represents an Account/Entity (in-memory State)"]
       [:li
        "you are "
        [:strong "NOT"]
        " forced to message driven architecture"]]]
     [:li
      "Zio Entity (discontinued)\n"
      [:ul [:li "inspired by Lagom and Aecor (both discontinued)"]]]
     [:li
      "EventSourced, EventStore ...\n"
      [:ul [:li "discontinued or not used much"]]]])},
  #uuid "deb3fcb2-4ff0-45be-8e38-ca8c85b50318"
  {:unit/title "Decentralized Banking",
   :unit/id #uuid "deb3fcb2-4ff0-45be-8e38-ca8c85b50318",
   :unit/type :unit/book,
   :unit/pos [1059.2607181084777 -419.213483791761],
   :unit/child-unit-ids [#uuid "5c94c570-6b48-423c-a068-6d9f6a6a5580"],
   :unit/props
   {:props/title-size :props/h2, :props/color :color/blue}},
  #uuid "1d815be7-3949-43b0-b317-0cc5eac86e8b"
  {:unit/parent-id #uuid "53c2197f-5c7d-4608-af3f-c1759b7d9f58",
   :unit/id #uuid "1d815be7-3949-43b0-b317-0cc5eac86e8b",
   :unit/type :unit/page,
   :unit/content
   ([:ul
     [:li
      [:strong "peer-2-peer"]
      " network and stateless Node are ideal for "
      [:a {:href "https://zio.dev/"} "ZIO"]]
     [:li
      "Blockchain and Projections are "
      [:strong "separated"]
      [:ul
       [:li
        "Blockchain = TxLedger + AccountState ("
        [:a
         {:href "https://github.com/pragmaxim/zio-chain"}
         "zio-chain"]
        ")"]
       [:li
        "Projections = "
        [:strong "Blockchain Explorer"]
        " ("
        [:a
         {:href "https://github.com/pragmaxim/ergo-uexplorer"}
         "uexplorer"]
        ")"]]]
     [:li
      "TxLedger + AccountState are "
      [:strong "provably correct"]
      " and consisent with each other and accross whole p2p network"
      [:img
       {:width "999",
        :src "/img/BLQ0c5EVNAI7xKdhuP7ktG",
        :style {:text-align "center"},
        :height "400"}]]]
    [:p])},
  #uuid "b781c423-c217-4aba-9e6b-6e184b2dceb8"
  {:unit/title "Crypto proofs for fast consensus",
   :unit/id #uuid "b781c423-c217-4aba-9e6b-6e184b2dceb8",
   :unit/type :unit/book,
   :unit/pos [3591.640752760418 636.0951592143513],
